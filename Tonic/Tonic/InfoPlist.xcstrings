    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic zeigt Ihren nächsten Termin in Top Shelf erst, nachdem Sie das Kalendermodul aktiviert haben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic shows your next event in Top Shelf only after you enable the Calendar module."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic muestra tu próximo evento en Top Shelf solo después de activar el módulo Calendario."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic affiche votre prochain événement dans Top Shelf uniquement après l’activation du module Calendrier."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonicは、カレンダーモジュールを有効にした後にのみTop Shelfに次の予定を表示します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅当您启用日历模块后，Tonic 才会在 Top Shelf 中显示下一个日程。"
          }
        }
      }
    },
    "NSFullDiskAccessUsageDescription" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic verwendet den Zugriff nur für von Ihnen geprüfte Orte bei Speicherdiagnose und Wiederherstellung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic uses access only for locations you review when diagnosing storage and recovery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic usa el acceso solo para las ubicaciones que revisas al diagnosticar almacenamiento y recuperación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic utilise l’accès uniquement pour les emplacements que vous examinez lors du diagnostic du stockage et de la récupération."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonicは、ストレージとリカバリの診断時に確認した場所にのみアクセスします。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tonic 仅在诊断存储和恢复时访问您已审核的位置。"
          }
        }
      }
    },
